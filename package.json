{
  "name": "steam-news-astro",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "generate": "tsx scripts/generate-content.ts",
    "generate:images": "tsx scripts/image-generator.ts",
    "generate:all": "npm run generate && npm run generate:images && npm run build",
    "fetch-trending": "tsx scripts/fetch-trending.ts",
    "generate:dynamic": "tsx scripts/generate-dynamic.ts",
    "orchestrate": "tsx scripts/orchestrate.ts",
    "auto": "tsx scripts/orchestrate.ts --mode full --limit 10",
    "translate": "tsx scripts/translate.ts",
    "translate:zh": "tsx scripts/translate.ts --lang zh",
    "translate:all": "tsx scripts/translate.ts --lang all",
    "predict": "tsx scripts/predict-hotness.ts",
    "predict:snapshot": "tsx scripts/predict-hotness.ts --snapshot",
    "notify:test": "tsx scripts/notify.ts",
    "n8n:api": "tsx scripts/n8n-api.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/tailwind": "^6.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^5.7.0",
    "date-fns": "^4.1.0",
    "pagefind": "^1.5.2",
    "tailwindcss": "^3.4.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
