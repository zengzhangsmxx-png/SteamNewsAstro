---
import { siteConfig } from '../../../site.config';
---

<footer class="border-t border-border-subtle bg-surface mt-16">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="font-display font-bold text-xl text-text-primary">{siteConfig.name}</a>
        <p class="mt-3 text-text-secondary text-sm max-w-md">{siteConfig.description}</p>
      </div>

      <!-- Sections -->
      <div>
        <h4 class="font-display font-semibold text-sm uppercase tracking-wider text-text-muted mb-3">Sections</h4>
        <ul class="space-y-2">
          {siteConfig.nav.map(item => (
            <li>
              <a href={item.href} class="text-text-secondary hover:text-steam text-sm transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h4 class="font-display font-semibold text-sm uppercase tracking-wider text-text-muted mb-3">Categories</h4>
        <ul class="space-y-2">
          {siteConfig.categories.slice(0, 6).map(cat => (
            <li>
              <a href={`/category/${cat.slug}`} class="text-text-secondary hover:text-steam text-sm transition-colors">
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-border-subtle flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-text-muted text-xs">
        &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="/rss.xml" class="text-text-muted hover:text-steam text-xs transition-colors">RSS Feed</a>
        <a href="/sitemap-index.xml" class="text-text-muted hover:text-steam text-xs transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
