---
import { siteConfig } from '../../../site.config';

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

const crumbs: Crumb[] = [
  { label: 'Home', href: '/' },
  ...items,
];
---

<nav aria-label="Breadcrumb" class="text-sm text-text-secondary">
  <ol class="flex items-center gap-1.5 flex-wrap">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span class="text-text-muted">/</span>}
        {i < crumbs.length - 1 ? (
          <a href={crumb.href} class="hover:text-steam transition-colors">
            {crumb.label}
          </a>
        ) : (
          <span class="text-text-primary">{crumb.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
