---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCard from '../components/ui/HeroCard.astro';
import ArticleCard from '../components/ui/ArticleCard.astro';
import Sidebar from '../components/ui/Sidebar.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../site.config';

const allNews = await getCollection('news', ({ data }) => !data.draft);
const allReviews = await getCollection('reviews', ({ data }) => !data.draft);
const allGuides = await getCollection('guides', ({ data }) => !data.draft);

const sortedNews = allNews.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const sortedReviews = allReviews.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const sortedGuides = allGuides.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const featured = sortedNews.find(p => p.data.featured) || sortedNews[0];
const restNews = sortedNews.filter(p => p.slug !== featured?.slug).slice(0, 4);
const latestReviews = sortedReviews.slice(0, 3);
const latestGuides = sortedGuides.slice(0, 3);

// All recent for "Latest" feed
const allRecent = [
  ...allNews.map(p => ({ ...p, _collection: 'news' as const })),
  ...allReviews.map(p => ({ ...p, _collection: 'reviews' as const })),
  ...allGuides.map(p => ({ ...p, _collection: 'guides' as const })),
].sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 8);
---

<BaseLayout
  title={siteConfig.name}
  description={siteConfig.description}
  type="website"
>
  <!-- Hero + Side cards -->
  <section class="max-w-7xl mx-auto px-4 md:px-6 pt-8 pb-4">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
      <!-- Featured hero (2/3) -->
      <div class="lg:col-span-2">
        {featured && (
          <HeroCard
            title={featured.data.title}
            description={featured.data.description}
            heroImage={featured.data.heroImage}
            heroImageAlt={featured.data.heroImageAlt}
            category={featured.data.category}
            publishDate={featured.data.publishDate}
            readingTime={featured.data.readingTime}
            slug={featured.slug}
            collection="news"
            gameTitle={featured.data.gameTitle}
          />
        )}
      </div>
      <!-- Side stack (1/3) -->
      <div class="flex flex-col gap-5">
        {restNews.slice(0, 2).map(post => (
          <a href={`/news/${post.slug}`} class="card group flex-1 flex flex-col">
            <div class="relative overflow-hidden aspect-[16/9] bg-elevated">
              <img src={post.data.heroImage} alt={post.data.heroImageAlt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-void/80 to-transparent" />
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <h3 class="font-display font-semibold text-sm leading-snug text-text-primary group-hover:text-steam transition-colors line-clamp-2">
                  {post.data.title}
                </h3>
                <span class="text-text-muted text-xs mt-1 block">{post.data.gameTitle}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Main content + Sidebar -->
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-6">
    <div class="flex flex-col lg:flex-row gap-10">

      <!-- Main column -->
      <div class="flex-1 min-w-0 space-y-12">

        <!-- Latest News -->
        <section>
          <div class="flex items-center justify-between mb-5">
            <h2 class="font-display font-bold text-xl flex items-center gap-2">
              <span class="w-1 h-5 bg-steam rounded-full inline-block"></span>
              Latest News
            </h2>
            <a href="/news" class="text-steam hover:text-steam-deep text-sm font-medium transition-colors">
              View all &rarr;
            </a>
          </div>
          <div class="space-y-4">
            {restNews.map(post => (
              <a href={`/news/${post.slug}`} class="card group flex flex-col sm:flex-row overflow-hidden">
                <div class="sm:w-48 shrink-0 aspect-video sm:aspect-auto overflow-hidden">
                  <img src={post.data.heroImage} alt={post.data.heroImageAlt}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                </div>
                <div class="p-4 flex flex-col justify-center">
                  <div class="flex items-center gap-2 mb-1.5">
                    {(() => {
                      const cat = siteConfig.categories.find(c => c.slug === post.data.category);
                      return (
                        <span class="text-xs font-medium uppercase tracking-wider" style={`color: ${cat?.color || '#66c0f4'}`}>
                          {cat?.label || post.data.category}
                        </span>
                      );
                    })()}
                    <span class="text-text-muted text-xs">·</span>
                    <span class="text-text-muted text-xs">{post.data.readingTime} min</span>
                  </div>
                  <h3 class="font-display font-semibold text-base leading-snug text-text-primary group-hover:text-steam transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="text-text-secondary text-sm mt-1.5 line-clamp-1 hidden sm:block">{post.data.description}</p>
                  <div class="flex items-center gap-2 mt-2 text-text-muted text-xs">
                    <span>{post.data.gameTitle}</span>
                    <span>·</span>
                    <time datetime={post.data.publishDate.toISOString()}>
                      {post.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    </time>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>

        <!-- Reviews -->
        <section>
          <div class="flex items-center justify-between mb-5">
            <h2 class="font-display font-bold text-xl flex items-center gap-2">
              <span class="w-1 h-5 bg-hot rounded-full inline-block"></span>
              Reviews
            </h2>
            <a href="/reviews" class="text-steam hover:text-steam-deep text-sm font-medium transition-colors">
              View all &rarr;
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {latestReviews.map(post => (
              <a href={`/reviews/${post.slug}`} class="card group block">
                <div class="relative overflow-hidden aspect-video">
                  <img src={post.data.heroImage} alt={post.data.heroImageAlt}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                  <div class="absolute top-3 left-3">
                    <span class="badge badge-hot text-xs uppercase tracking-wider">Review</span>
                  </div>
                  <div class="absolute top-3 right-3">
                    <span class:list={[
                      'inline-flex items-center justify-center w-9 h-9 rounded-lg font-display font-bold text-sm',
                      post.data.rating >= 8 ? 'bg-accent-success/90 text-void' :
                      post.data.rating >= 6 ? 'bg-accent-warning/90 text-void' :
                      'bg-accent-danger/90 text-white'
                    ]}>
                      {post.data.rating}
                    </span>
                  </div>
                </div>
                <div class="p-4">
                  <h3 class="font-display font-semibold text-base leading-snug text-text-primary group-hover:text-steam transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="text-text-secondary text-sm mt-1.5 line-clamp-2">{post.data.description}</p>
                  <div class="flex items-center gap-2 mt-2 text-text-muted text-xs">
                    <span>{post.data.gameTitle}</span>
                    <span>·</span>
                    <span>{post.data.readingTime} min read</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>

        <!-- Guides -->
        <section>
          <div class="flex items-center justify-between mb-5">
            <h2 class="font-display font-bold text-xl flex items-center gap-2">
              <span class="w-1 h-5 bg-accent-success rounded-full inline-block"></span>
              Guides
            </h2>
            <a href="/guides" class="text-steam hover:text-steam-deep text-sm font-medium transition-colors">
              View all &rarr;
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {latestGuides.map(post => (
              <a href={`/guides/${post.slug}`} class="card group block">
                <div class="relative overflow-hidden aspect-video">
                  <img src={post.data.heroImage} alt={post.data.heroImageAlt}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                  <div class="absolute top-3 left-3">
                    <span class="badge text-xs uppercase tracking-wider" style="background: rgba(52,211,153,0.15); color: #34d399; border-color: rgba(52,211,153,0.3);">
                      Guide
                    </span>
                  </div>
                </div>
                <div class="p-4">
                  <h3 class="font-display font-semibold text-base leading-snug text-text-primary group-hover:text-steam transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="text-text-secondary text-sm mt-1.5 line-clamp-2">{post.data.description}</p>
                  <div class="flex items-center gap-2 mt-2 text-text-muted text-xs">
                    <span>{post.data.gameTitle}</span>
                    <span>·</span>
                    <span>{post.data.readingTime} min read</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>

      </div>

      <!-- Sidebar -->
      <aside class="w-full lg:w-72 shrink-0">
        <div class="lg:sticky lg:top-20 space-y-6">
          <Sidebar />

          <!-- Newsletter CTA -->
          <div class="card p-5 text-center">
            <h3 class="font-display font-bold text-sm uppercase tracking-wider text-steam mb-2">Stay Updated</h3>
            <p class="text-text-secondary text-xs mb-3">Get the latest Steam news delivered to your inbox.</p>
            <a href="/rss.xml" class="btn btn-primary text-sm w-full">
              Subscribe via RSS
            </a>
          </div>
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>
