---
import { siteConfig } from '../../site.config';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import OpenGraph from '../components/seo/OpenGraph.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  type?: 'website' | 'article' | 'review';
  image?: string;
  imageAlt?: string;
  publishDate?: Date;
  updatedDate?: Date;
  author?: { name: string; bio: string };
  tags?: string[];
  gameTitle?: string;
  steamAppId?: number;
  rating?: number;
  faq?: { question: string; answer: string }[];
  breadcrumbs?: { name: string; url: string }[];
  noindex?: boolean;
}

const {
  title, description, type = 'website',
  image, imageAlt, publishDate, updatedDate,
  author, tags, gameTitle, steamAppId,
  rating, faq, breadcrumbs, noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).toString();
const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
---

<!doctype html>
<html lang={siteConfig.language}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href="/rss.xml" />

  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Preconnect Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Analytics -->
  {siteConfig.analytics.plausible && (
    <script defer data-domain={siteConfig.analytics.plausible} src="https://plausible.io/js/script.js" is:inline></script>
  )}
  {siteConfig.analytics.googleAnalytics && (
    <Fragment>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${siteConfig.analytics.googleAnalytics}`} is:inline></script>
      <script is:inline define:vars={{ gaId: siteConfig.analytics.googleAnalytics }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </Fragment>
  )}

  <OpenGraph
    title={pageTitle}
    description={description}
    url={canonicalUrl}
    type={type === 'review' ? 'article' : type}
    image={image}
    imageAlt={imageAlt}
    publishDate={publishDate}
    updatedDate={updatedDate}
    author={author?.name}
    tags={tags}
  />

  <SchemaOrg
    type={type}
    title={title}
    description={description}
    url={canonicalUrl}
    publishDate={publishDate}
    updatedDate={updatedDate}
    author={author}
    heroImage={image}
    heroImageAlt={imageAlt}
    gameTitle={gameTitle}
    steamAppId={steamAppId}
    rating={rating}
    tags={tags}
    faq={faq}
    breadcrumbs={breadcrumbs}
  />
</head>
<body class="min-h-screen flex flex-col">
  <Navbar />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
