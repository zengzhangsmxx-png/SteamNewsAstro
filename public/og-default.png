<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0b0d12"/>
      <stop offset="100%" style="stop-color:#12151c"/>
    </linearGradient>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(102,192,244,0.05)" stroke-width="1"/>
    </pattern>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect width="1200" height="630" fill="url(#grid)"/>
  <circle cx="600" cy="240" r="60" fill="none" stroke="#66c0f4" stroke-width="3"/>
  <path d="M600 200L600 240L624 256" stroke="#66c0f4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  <circle cx="600" cy="240" r="8" fill="#66c0f4"/>
  <text x="600" y="360" font-family="sans-serif" font-size="48" font-weight="700" fill="#e4e8f1" text-anchor="middle">SteamPulse</text>
  <text x="600" y="400" font-family="sans-serif" font-size="20" fill="#8b93a7" text-anchor="middle">Your daily source for Steam gaming news</text>
</svg>
